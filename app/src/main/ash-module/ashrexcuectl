#!/system/bin/sh

# Typed control surface for the native companion app.
# This script intentionally has no generic shell/exec command.
MODPATH="${0%/*}"
. "$MODPATH/utils.sh" >/dev/null 2>&1 || {
  printf '{"ok":false,"message":"failed to load AshReXcue runtime"}\n'
  exit 1
}
. "$MODPATH/external-control.sh" >/dev/null 2>&1 || {
  printf '{"ok":false,"message":"failed to load AshReXcue external-control runtime"}\n'
  exit 1
}
initialize_storage >/dev/null 2>&1 || true
JQ_BIN="$JQ"

single_line() {
  printf '%s' "$1" | tr '\r\n' '  ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

ensure_jq_runtime() {
  [ -x "$JQ_BIN" ] && return 0
  if [ -f "$JQ_BIN" ]; then
    chmod 755 "$JQ_BIN" 2>/dev/null || true
  fi
  [ -x "$JQ_BIN" ]
}

json_result() {
  local ok="$1" message="$2" path="$3"
  message=$(single_line "$message")
  if ensure_jq_runtime; then
    if [ -n "$path" ]; then
      "$JQ_BIN" -cn --argjson ok "$ok" --arg message "$message" --arg path "$path" '{ok:$ok,message:$message,path:$path}'
    else
      "$JQ_BIN" -cn --argjson ok "$ok" --arg message "$message" '{ok:$ok,message:$message}'
    fi
  else
    printf '{"ok":%s,"message":"%s"' "$ok" "$(json_escape "$message")"
    [ -n "$path" ] && printf ',"path":"%s"' "$(json_escape "$path")"
    printf '}\n'
  fi
}

json_error() { json_result false "$1" ""; }
json_success() { json_result true "$1" "$2"; }

capture_mutation() {
  local out_file rc message
  out_file="$ASHLOOPER_DIR/.ctl-out.$$"
  "$@" >"$out_file" 2>&1
  rc=$?
  message=$(cat "$out_file" 2>/dev/null)
  rm -f "$out_file"
  [ -n "$message" ] || message="Operation completed."
  if [ "$rc" -eq 0 ]; then json_success "$message"; else json_error "$message"; fi
  return "$rc"
}

modules_json() {
  create_mod_list >/dev/null 2>&1 || { json_error "Unable to build module inventory."; return 1; }
  ensure_jq_runtime || { printf '{"items":[]}\n'; return 0; }
  if [ -f "$MODULE_LIST" ]; then
    "$JQ_BIN" -c --slurpfile stable "$MODULE_LIST" '
      {items: map(
        . as $current |
        (($stable[0] // []) | map(select(((.folder // .id) == $current.folder) or (.id == $current.id))) | .[0] // null) as $previous |
        {
          folder,id,name,version,versionCode,
          enabled:(.status=="enabled"),
          quarantined,trust,baseTrust,fingerprint,
          changedSinceStable:(
            $previous == null or
            (if (($previous.fingerprint // "") != "") then
              (.fingerprint != $previous.fingerprint or .id != $previous.id)
            else
              (.name != $previous.name or .version != $previous.version or .versionCode != $previous.versionCode or .id != $previous.id)
            end)
          )
        }
      )}
    ' "$TMP_FILE"
  else
    "$JQ_BIN" -c '{items: map({folder,id,name,version,versionCode,enabled:(.status=="enabled"),quarantined,trust,baseTrust,fingerprint,changedSinceStable:true})}' "$TMP_FILE"
  fi
}

quarantine_json() {
  local first folder id name trust rescue_id disabled_at exists disable_present reason
  first=1
  printf '{"items":['
  while IFS="$(printf '\t')" read -r folder id name trust rescue_id disabled_at exists disable_present; do
    [ -n "$folder" ] || continue
    [ "$first" -eq 0 ] && printf ','
    reason=$(get_prop reason "$QUARANTINE_DIR/$folder.prop")
    printf '{"folder":"%s","id":"%s","name":"%s","trust":"%s","rescueId":"%s","disabledAt":%s,"exists":%s,"disablePresent":%s,"reason":"%s"}' \
      "$(json_escape "$folder")" "$(json_escape "$id")" "$(json_escape "$name")" "$(json_escape "$trust")" "$(json_escape "$rescue_id")" "${disabled_at:-0}" "${exists:-false}" "${disable_present:-false}" "$(json_escape "$reason")"
    first=0
  done <<EOF_Q
$(list_quarantined_modules_tsv)
EOF_Q
  printf ']}\n'
}

settings_json() {
  local keys first key pending
  keys='mode threshold timeout timeout_min timeout_max stability_time failure_threshold check_interval restart_limit boot_ready_consecutive extra_stability systemui_process monitored_processes missing_process_action boot_animation_required ce_storage_required first_boot_grace ota_grace_time'
  first=1
  printf '{"items":['
  for key in $keys; do
    [ "$first" -eq 0 ] && printf ','
    printf '{"key":"%s","value":"%s","editable":true}' "$(json_escape "$key")" "$(json_escape "$(get_prop "$key")")"
    first=0
  done
  printf '],"pending":'
  if ensure_jq_runtime; then
    pending=$(pending_settings_json 2>/dev/null)
    printf '%s' "$pending" | "$JQ_BIN" -c '.items // []' 2>/dev/null || printf '[]'
  else
    printf '[]'
  fi
  printf '}\n'
}

activity_json() {
  local limit tmp id timestamp result mode count reason recommendation folder outcome key
  limit="${1:-100}"
  case "$limit" in ''|*[!0-9]*) limit=100 ;; esac
  [ "$limit" -gt 200 ] && limit=200
  [ "$limit" -lt 1 ] && limit=1
  tmp="$ASHLOOPER_DIR/.activity.$$"
  : > "$tmp"
  if ensure_jq_runtime; then
    rescue_history_json 200 0 all all "" | "$JQ_BIN" -c '.items[] | {id:.rescueId,timestamp:(.createdAt//0),type:"rescue",title:("Rescue · "+(.stage//"unknown")),subtitle:(.reason//""),status:(.status//"unknown"),details:(([.modules[]? | ((.name//.id//.folder)+" ["+(.folder//"")+"]")] | join("\n")))}' 2>/dev/null >> "$tmp"
  fi
  while IFS="$(printf '\t')" read -r id timestamp result mode count reason; do
    [ -n "$id" ] || continue
    printf '{"id":"%s","timestamp":%s,"type":"restoration","title":"Restoration · %s","subtitle":"%s module(s) · %s","status":"%s","details":"%s"}\n' \
      "$(json_escape "$id")" "${timestamp:-0}" "$(json_escape "$mode")" "${count:-0}" "$(json_escape "$reason")" "$(json_escape "$result")" "$(json_escape "$reason")"
  done <<EOF_R >> "$tmp"
$(list_restore_history_tsv 200)
EOF_R
  if [ -f "$ASH_EXTERNAL_OUTCOMES" ]; then
    while IFS="$(printf '\t')" read -r timestamp recommendation folder outcome key; do
      [ -n "$recommendation" ] || continue
      printf '{"id":"guidance-%s-%s","timestamp":%s,"type":"guidance","title":"Guidance outcome · %s","subtitle":"%s · %s","status":"%s","details":"idempotency=%s"}\n' \
        "$(json_escape "$recommendation")" "${timestamp:-0}" "${timestamp:-0}" "$(json_escape "$outcome")" "$(json_escape "$folder")" "$(json_escape "$recommendation")" "$(json_escape "$outcome")" "$(json_escape "$key")"
    done < "$ASH_EXTERNAL_OUTCOMES" >> "$tmp"
  fi
  if ensure_jq_runtime; then
    "$JQ_BIN" -s --argjson limit "$limit" '{items:(sort_by(.timestamp)|reverse|.[0:$limit])}' "$tmp"
  else
    printf '{"items":[]}\n'
  fi
  rm -f "$tmp"
}


capabilities_json() {
  local version version_code
  version=$(get_prop version "$MODPATH/module.prop")
  version_code=$(get_prop versionCode "$MODPATH/module.prop")
  case "$version_code" in ''|*[!0-9]*) version_code=0 ;; esac
  if ensure_jq_runtime; then
    "$JQ_BIN" -cn \
      --arg version "$version" \
      --argjson versionCode "$version_code" \
      '{ok:true,apiVersion:2,minimumClientApi:2,moduleVersion:$version,moduleVersionCode:$versionCode,features:["snapshot","capabilities","trust-management","restore-trials","guided-recovery","recovery-plans","diagnostic-export","queued-settings","event-history","external-control-v1","automation-receipts","one-shot-tokens","idempotency","state-health","state-repair","snapshot-schema-2","release-gate-v1"]}'
  else
    printf '{"ok":true,"apiVersion":2,"minimumClientApi":2,"moduleVersion":"%s","moduleVersionCode":%s,"features":["snapshot","capabilities","trust-management","restore-trials","guided-recovery","recovery-plans","diagnostic-export","queued-settings","event-history","external-control-v1","automation-receipts","one-shot-tokens","idempotency","state-health","state-repair","snapshot-schema-2","release-gate-v1"]}\n' \
      "$(json_escape "$version")" "$version_code"
  fi
}

recovery_revision() {
  {
    printf 'restore_state=%s\n' "$(get_prop state "$RESTORE_STATE")"
    if [ -f "$RESTORE_TRIAL" ]; then
      printf 'restore_trial=%s\n' "$(wc -l < "$RESTORE_TRIAL" | tr -d ' ')"
    else
      printf 'restore_trial=0\n'
    fi
    list_quarantined_modules_tsv
  } | cksum | awk '{printf "%s-%s", $1, $2}'
}

release_gate_add() {
  local id="$1" title="$2" state="$3" detail="$4"
  printf '%s\t%s\t%s\t%s\n' \
    "$(single_line "$id")" \
    "$(single_line "$title")" \
    "$(single_line "$state")" \
    "$(single_line "$detail")" >> "$RELEASE_GATE_CHECKS"
}

release_gate_json() {
  local version version_code generated_at health_json health_status health_issues restore_state scripts_ok storage_ok external_ok settings_ok
  ensure_jq_runtime || { json_error "AshReXcue release gate requires the bundled jq runtime."; return 1; }
  RELEASE_GATE_CHECKS="$ASHLOOPER_DIR/.release-gate-checks.$$"
  : > "$RELEASE_GATE_CHECKS" || { json_error "Unable to create release-gate workspace."; return 1; }

  version=$(get_prop version "$MODPATH/module.prop")
  version_code=$(get_prop versionCode "$MODPATH/module.prop")
  case "$version_code" in ''|*[!0-9]*) version_code=0 ;; esac
  generated_at=$(date +%s 2>/dev/null || echo 0)

  release_gate_add jq-runtime 'Bundled JSON runtime' pass 'Bundled jq is executable.'

  scripts_ok=true
  for script in ashrexcuectl action.sh customize.sh post-fs-data.sh service.sh uninstall.sh utils.sh external-control.sh; do
    [ -x "$MODPATH/$script" ] || scripts_ok=false
  done
  if [ "$scripts_ok" = true ]; then
    release_gate_add control-scripts 'Typed control scripts' pass 'All release-critical scripts are executable.'
  else
    release_gate_add control-scripts 'Typed control scripts' blocker 'One or more release-critical scripts are missing or not executable.'
  fi

  if [ -n "$version" ] && [ "$version_code" -ge 260 ]; then
    release_gate_add module-metadata 'Module metadata' pass "Module $version ($version_code) has release metadata."
  else
    release_gate_add module-metadata 'Module metadata' blocker 'Module version metadata is missing or older than the Phase J release baseline.'
  fi

  storage_ok=true
  for path in "$ASHLOOPER_DIR" "$LOG_DIR" "$RESCUE_DIR" "$QUARANTINE_DIR" "$RESTORE_HISTORY_DIR"; do
    [ -d "$path" ] && [ -w "$path" ] || storage_ok=false
  done
  if [ "$storage_ok" = true ]; then
    release_gate_add durable-storage 'Durable storage' pass 'Recovery state directories exist and are writable.'
  else
    release_gate_add durable-storage 'Durable storage' blocker 'A recovery state directory is missing or not writable.'
  fi

  health_json=$(state_health_json 2>/dev/null)
  health_status=$(printf '%s' "$health_json" | "$JQ_BIN" -r '.status // "unknown"' 2>/dev/null)
  health_issues=$(printf '%s' "$health_json" | "$JQ_BIN" -r '.issueCount // 0' 2>/dev/null)
  case "$health_status" in
    healthy) release_gate_add state-health 'Durable state health' pass 'State schema and durable recovery records are consistent.' ;;
    degraded) release_gate_add state-health 'Durable state health' warning "State health is degraded with ${health_issues:-0} issue(s)." ;;
    *) release_gate_add state-health 'Durable state health' blocker "State health is ${health_status:-unknown} with ${health_issues:-0} issue(s)." ;;
  esac

  restore_state=$(get_prop state "$RESTORE_STATE")
  [ -n "$restore_state" ] || restore_state=idle
  if [ "$restore_state" = testing ]; then
    release_gate_add restoration-idle 'Restoration state' blocker 'A restoration trial is active.'
  else
    release_gate_add restoration-idle 'Restoration state' pass 'No restoration trial is active.'
  fi

  external_ok=true
  command -v ash_external_dispatch >/dev/null 2>&1 || external_ok=false
  ash_external_init >/dev/null 2>&1 || external_ok=false
  if [ "$external_ok" = true ]; then
    release_gate_add external-control 'External-control safety' pass 'Token, receipt, rate-limit, and idempotency storage is available.'
  else
    release_gate_add external-control 'External-control safety' blocker 'External-control safety storage could not be initialized.'
  fi

  settings_ok=true
  [ -r "$MODPATH/settings.prop" ] || settings_ok=false
  [ -n "$(get_prop threshold)" ] || settings_ok=false
  if [ "$settings_ok" = true ]; then
    release_gate_add settings-contract 'Protection settings' pass 'Required boot-protection settings are readable.'
  else
    release_gate_add settings-contract 'Protection settings' blocker 'Required boot-protection settings are missing or unreadable.'
  fi

  release_gate_add mutation-surface 'Mutation surface' pass 'The control CLI exposes typed commands and no generic shell execution action.'
  release_gate_add protocol 'Release protocol' pass 'ashrexcue.release.v1 is active.'

  "$JQ_BIN" -Rn \
    --arg protocolVersion 'ashrexcue.release.v1' \
    --arg moduleVersion "$version" \
    --argjson moduleVersionCode "$version_code" \
    --argjson generatedAt "$generated_at" '
      [inputs | split("\t") | {id:.[0],title:.[1],state:.[2],detail:.[3]}] as $checks |
      ($checks | map(select(.state == "blocker")) | length) as $blockers |
      ($checks | map(select(.state == "warning")) | length) as $warnings |
      {
        ok:true,
        protocolVersion:$protocolVersion,
        generatedAt:$generatedAt,
        moduleVersion:$moduleVersion,
        moduleVersionCode:$moduleVersionCode,
        status:(if $blockers > 0 then "blocked" elif $warnings > 0 then "ready-with-warnings" else "ready" end),
        checks:$checks
      }
    ' < "$RELEASE_GATE_CHECKS"
  local rc=$?
  rm -f "$RELEASE_GATE_CHECKS"
  RELEASE_GATE_CHECKS=''
  return "$rc"
}

snapshot_json() {
  local limit work rc generated_at recovery_revision_value
  limit="${1:-150}"
  case "$limit" in ''|*[!0-9]*) limit=150 ;; esac
  [ "$limit" -gt 200 ] && limit=200
  [ "$limit" -lt 1 ] && limit=1
  ensure_jq_runtime || { json_error "AshReXcue snapshot requires the bundled jq runtime."; return 1; }

  work="$ASHLOOPER_DIR/.snapshot.$$"
  rm -rf "$work"
  mkdir -p "$work" || { json_error "Unable to create snapshot workspace."; return 1; }
  rc=0
  capabilities_json > "$work/capabilities.json" || rc=1
  dashboard_json > "$work/dashboard.json" || rc=1
  modules_json > "$work/modules.json" || rc=1
  quarantine_json > "$work/quarantine.json" || rc=1
  activity_json "$limit" > "$work/activity.json" || rc=1
  settings_json > "$work/settings.json" || rc=1
  pending_settings_json > "$work/pending.json" || rc=1
  state_health_json > "$work/health.json" || rc=1
  if [ "$rc" -ne 0 ]; then
    rm -rf "$work"
    json_error "Unable to assemble a consistent AshReXcue snapshot."
    return 1
  fi

  generated_at=$(date +%s 2>/dev/null || echo 0)
  recovery_revision_value=$(recovery_revision)
  "$JQ_BIN" -cn \
    --argjson generatedAt "$generated_at" \
    --arg recoveryRevision "$recovery_revision_value" \
    --slurpfile capabilities "$work/capabilities.json" \
    --slurpfile dashboard "$work/dashboard.json" \
    --slurpfile modules "$work/modules.json" \
    --slurpfile quarantine "$work/quarantine.json" \
    --slurpfile activity "$work/activity.json" \
    --slurpfile settings "$work/settings.json" \
    --slurpfile pending "$work/pending.json" \
    --slurpfile health "$work/health.json" \
    '{
      ok:true,
      schemaVersion:2,
      generatedAt:$generatedAt,
      recoveryRevision:$recoveryRevision,
      capabilities:($capabilities[0] // {}),
      dashboard:($dashboard[0] // {}),
      modules:(($modules[0] // {}).items // []),
      quarantine:(($quarantine[0] // {}).items // []),
      activity:(($activity[0] // {}).items // []),
      settings:(($settings[0] // {}).items // []),
      pendingSettings:(($pending[0] // {}).items // []),
      health:($health[0] // {})
    }'
  rc=$?
  rm -rf "$work"
  return "$rc"
}

command="$1"
mode=""; value=""; plan_id=""; recovery_revision_value=""; old_ifs=""; folder=""; output=""; rc=0; path=""; selected_count=0
[ "$#" -gt 0 ] && shift
case "$command" in
  automation) ash_external_dispatch "$@" ;;
  capabilities) capabilities_json ;;
  snapshot) snapshot_json "$1" ;;
  release-gate) release_gate_json ;;
  health) state_health_json ;;
  repair-state) capture_mutation repair_recovery_state ;;
  status) dashboard_json ;;
  modules) modules_json ;;
  quarantine) quarantine_json ;;
  activity) activity_json "$1" ;;
  settings) settings_json ;;
  pending-settings) pending_settings_json ;;
  set-setting)
    [ "$#" -eq 2 ] || { json_error "Expected setting key and value."; exit 2; }
    capture_mutation settings_set "$1" "$2"
    ;;
  set-settings)
    [ "$#" -gt 0 ] && [ $(( $# % 2 )) -eq 0 ] || { json_error "Expected one or more setting key/value pairs."; exit 2; }
    capture_mutation settings_batch_set "$@"
    ;;
  set-trust)
    [ "$#" -eq 2 ] || { json_error "Expected module folder and trust category."; exit 2; }
    case "$1" in ''|*[!A-Za-z0-9._-]*) json_error "Invalid module folder."; exit 2 ;; esac
    case "$2" in protected|trusted|normal|suspect) ;; *) json_error "Invalid trust category."; exit 2 ;; esac
    capture_mutation set_module_trust "$2" "$1"
    ;;
  restore)
    mode="$1"; value="$2"
    case "$mode" in
      one)
        case "$value" in ''|*[!A-Za-z0-9._-]*) json_error "A valid module folder is required."; exit 2 ;; esac
        capture_mutation restore_quarantined_modules individual "$value"
        ;;
      selected)
        [ -n "$value" ] || { json_error "At least one module folder is required."; exit 2; }
        old_ifs="$IFS"; IFS=','; selected_count=0
        for folder in $value; do
          case "$folder" in ''|*[!A-Za-z0-9._-]*) IFS="$old_ifs"; json_error "Invalid module folder."; exit 2 ;; esac
          selected_count=$((selected_count + 1))
          [ "$selected_count" -le 64 ] || { IFS="$old_ifs"; json_error "Too many module folders."; exit 2; }
        done
        IFS="$old_ifs"
        capture_mutation restore_quarantined_modules selected "$value"
        ;;
      planned)
        plan_id="$2"; recovery_revision_value="$3"; value="$4"
        case "$plan_id" in ''|*[!A-Za-z0-9._-]*) json_error "Invalid recovery plan identifier."; exit 2 ;; esac
        case "$recovery_revision_value" in ''|*[!A-Za-z0-9._:-]*) json_error "Invalid recovery revision."; exit 2 ;; esac
        [ -n "$value" ] || { json_error "At least one recovery plan module is required."; exit 2; }
        old_ifs="$IFS"; IFS=','; selected_count=0
        for folder in $value; do
          case "$folder" in ''|*[!A-Za-z0-9._-]*) IFS="$old_ifs"; json_error "Invalid module folder."; exit 2 ;; esac
          selected_count=$((selected_count + 1))
          [ "$selected_count" -le 8 ] || { IFS="$old_ifs"; json_error "Recovery plan exceeds the safety limit."; exit 2; }
        done
        IFS="$old_ifs"
        capture_mutation restore_quarantined_modules planned "$value" "$recovery_revision_value" "$plan_id"
        ;;
      half|all) capture_mutation restore_quarantined_modules "$mode" "" ;;
      *) json_error "Invalid restore mode."; exit 2 ;;
    esac
    ;;
  complete-trial) capture_mutation complete_restore_trial ;;
  rollback-trial) capture_mutation rollback_restore_trial "rolled back from companion app" ;;
  discard-pending-settings) capture_mutation discard_pending_settings ;;
  diagnostic-export)
    output=$(create_diagnostic_export 2>&1); rc=$?
    path=$(printf '%s\n' "$output" | sed -n 's/^Diagnostic export: //p' | tail -n 1)
    [ -n "$path" ] || path=$(list_diagnostic_exports_tsv 1 | cut -f1)
    if [ "$rc" -eq 0 ]; then json_success "${output:-Diagnostic export created.}" "$path"; else json_error "${output:-Diagnostic export failed.}"; fi
    exit "$rc"
    ;;
  *) json_error "Unsupported command."; exit 2 ;;
esac
